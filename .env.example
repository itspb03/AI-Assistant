
ANTHROPIC_API_KEY=your_anthropic_key_here

# Model tiers for chat vs background organization
CLAUDE_CHAT_MODEL=claude-3-5-sonnet-20241022
CLAUDE_AGENT_MODEL=claude-3-5-haiku-20241022

# Legacy alias  
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Output token caps per tier
CLAUDE_CHAT_MAX_TOKENS=2048
CLAUDE_AGENT_MAX_TOKENS=4096

# API key for Gemini 1.5 Flash (Vision analysis)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=512

# Public URL of your Supabase project
SUPABASE_URL=https://your-project.supabase.co

# IMPORTANT: Use the SERVICE_ROLE (secret) key for storage access
SUPABASE_KEY=your_service_role_key_here

# Postgres URI for Automated SQL Migrations
# Format: postgresql://postgres.[ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=your_postgres_uri_here


# "mock" | "stability" | "dalle"
IMAGE_PROVIDER=mock


# Directory where project memory JSON files are stored
MEMORY_STORE_PATH=./memory_store

# Set to true to skip ALL LLM API calls during UI/frontend dev
MOCK_AI=false

#  App Environment 

APP_ENV=development
LOG_LEVEL=INFO
