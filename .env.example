
# Main API key for Groq
GROQ_API_KEY=gsk_your_groq_key_here

# Model tiers for chat vs background organization
GROQ_CHAT_MODEL=llama3-groq-70b-8192-tool-use-preview
GROQ_AGENT_MODEL=llama-3.3-70b-versatile

# Output token cap
LLM_MAX_TOKENS=2048

# API key for Gemini (Vision analysis)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=512

# Public URL of your Supabase project
SUPABASE_URL=https://your-project.supabase.co

# IMPORTANT: Use the SERVICE_ROLE (secret) key for storage access
SUPABASE_KEY=your_service_role_key_here

# Format: postgresql://postgres.[ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=your_postgres_uri_here

IMAGE_PROVIDER=mock

# Directory where project memory JSON files are stored
MEMORY_STORE_PATH=./memory_store

# Set to true to skip ALL LLM API calls during UI/frontend dev
MOCK_AI=false

APP_ENV=development
LOG_LEVEL=INFO
